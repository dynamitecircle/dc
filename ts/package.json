{
  "name": "@dynamitecircle/dc",
  "version": "2.0.4",
  "description": "Official TypeScript client for the public Dynamite Circle Member API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm run test",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "dynamite-circle",
    "dc",
    "membership",
    "events",
    "dcbkk",
    "dcmex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dynamitecircle/dc.git",
    "directory": "ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
