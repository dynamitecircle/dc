# API keys — never commit
.env
.env.local
.env.*.local
.env.dc
**/.env.dc

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.venv*
*.egg-info/
dist/
build/

# Node (in case any tool ships a sub-app)
node_modules/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Runtime state — written by Skill.check_and_run_migrations() on first run.
# Per-install local state; never commit (would push your local migration
# timestamps to every package consumer).
metadata/
